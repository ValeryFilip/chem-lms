generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  name           String?
  role           UserRole       @default(STUDENT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  enrollments    Enrollment[]
  submissions    Submission[]
  progresses     Progress[]
  stepProgresses StepProgress[]
}

model Subject {
  id      String   @id @default(cuid())
  slug    String   @unique
  title   String
  courses Course[]
}

model Course {
  id          String       @id @default(cuid())
  subjectId   String
  slug        String       @unique
  title       String
  description String?
  coverImage  String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subject     Subject      @relation(fields: [subjectId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
  progresses  Progress[]
}

model Module {
  id       String   @id @default(cuid())
  courseId String
  title    String
  order    Int

  course   Course   @relation(fields: [courseId], references: [id])
  lessons  Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  order       Int
  isPublished Boolean  @default(false)

  module      Module      @relation(fields: [moduleId], references: [id])
  progresses  Progress[]
  steps       Step[]
}

model Step {
  id          String   @id @default(cuid())
  lessonId    String
  title       String
  type        String
  order       Int
  content     Json
  isPublished Boolean  @default(false)

  lesson      Lesson          @relation(fields: [lessonId], references: [id])
  submissions Submission[]
  progresses  StepProgress[]
}

model Submission {
  id            String   @id @default(cuid())
  userId        String
  stepId        String
  answerPayload Json
  resultPayload Json?
  isCorrect     Boolean
  score         Float    @default(0)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  step          Step     @relation(fields: [stepId], references: [id])
}

model StepProgress {
  id          String   @id @default(cuid())
  userId      String
  stepId      String
  status      String
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  step        Step     @relation(fields: [stepId], references: [id])

  @@unique([userId, stepId])
}

model Progress {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  lessonId   String?
  status     String
  percent    Float    @default(0)
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])
  lesson     Lesson?  @relation(fields: [lessonId], references: [id])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  accessType String
  status     String
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}